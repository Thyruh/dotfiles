#!/usr/bin/env bash
BINARY="main"
TARGET_DIR="$PWD"
CFLAGS="-O3 -std=c23 -Wall -Wextra -pedantic -Wshadow -Wconversion -Wsign-conversion -Wno-stringop-overread"

# pipe the arguments if needed

if [ -f "$TARGET_DIR/${BINARY}.c" ]; then
   time gcc "$TARGET_DIR"/*.c $CFLAGS -o "$TARGET_DIR/$BINARY" && time "$TARGET_DIR/$BINARY" || exit 1
fi
